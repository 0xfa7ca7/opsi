{
  "name": "opsi",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "opsi": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "pnpm --filter @opsi/domain --filter @opsi/config --filter @opsi/output --filter @opsi/storage --filter @opsi/core --filter @opsi/provider-opsi build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opsi/config": "workspace:*",
    "@opsi/core": "workspace:*",
    "@opsi/domain": "workspace:*",
    "@opsi/output": "workspace:*",
    "@opsi/provider-opsi": "workspace:*",
    "@opsi/storage": "workspace:*",
    "commander": "15.0.0",
    "undici": "8.7.0"
  }
}
