{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "types": ["node"],
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "paths": {
