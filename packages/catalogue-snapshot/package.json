{
  "name": "@klopsi/catalogue-snapshot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "node dist/publish-entry.js",
    "verify-public": "node dist/verify-entry.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@klopsi/domain": "workspace:*",
    "@klopsi/provider-klopsi": "workspace:*",
    "@klopsi/storage": "workspace:*",
    "zod": "4.4.3"
  }
}
